{
  "name": "abrir-mvp",
  "version": "0.1.0",
  "description": "ABRIR MVP built on a deterministic Three.js procedural map generator.",
  "type": "module",
  "author": "Esat Boucaud",
  "license": "MIT",
  "keywords": [
    "three.js",
    "procedural-generation",
    "roguelike",
    "webgl",
    "gamedev",
    "abrir"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "generate:map": "node scripts/generate-abrir-map.mjs",
    "validate:maps": "node scripts/validate-map-states.mjs",
    "validate:search": "node scripts/validate-search-scenes.mjs",
    "check": "npm run generate:map && npm run validate:maps && npm run validate:search && npm run build"
  },
  "dependencies": {
    "three": "^0.185.0"
  },
  "devDependencies": {
    "vite": "^8.0.0"
  }
}
